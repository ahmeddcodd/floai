# Frontend
NEXT_PUBLIC_API_BASE_URL=https://cod-automation.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Optional: set this to your Supabase custom/vanity domain (for OAuth branding),
# for example: https://auth.floai.pk or https://my-brand.supabase.co
NEXT_PUBLIC_SUPABASE_CUSTOM_DOMAIN_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Meta WhatsApp Embedded Signup
NEXT_PUBLIC_META_APP_ID=your_meta_app_id
NEXT_PUBLIC_META_CONFIG_ID=your_meta_config_id
